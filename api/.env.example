# Mirror API (existing deployed API)
MIRROR_API_URL=https://your-mirror-api.railway.app

# x402 Payment (Coinbase payment protocol on Base)
MIRROR_WALLET_ADDRESS=0x...   # Your wallet on Base to receive USDC payments
REQUIRE_PAYMENT=false          # Set true to enforce x402 payment gating
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# Credential signing
CREDENTIAL_SECRET=change-me-to-a-random-secret

# Server
PORT=3002
CORS_ORIGIN=http://localhost:3000
